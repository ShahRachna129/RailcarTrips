
@page "/railcar-trips"
@using Shared
@inject HttpClient Http

<h3>Railcar Trips</h3>

@*<InputFile OnChange="UploadFile" />*@
<br />
<br />

@if (Trips != null)
{
    <table class="table table-striped">
        <thead>
            <tr>
                @*<th>Trip ID</th>*@
                <th>Equipment ID</th>
                <th>Origin</th>
                <th>Destination</th>
                <th>Start UTC</th>
                <th>End UTC</th>
                <th>Total Hours</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var trip in Trips)
            {
                <tr>
                    @*<td>@trip.TripID</td>*@
                    <td>@trip.Equipment_Id</td>
                    <td>@trip.OriginCity</td>
                    <td>@trip.DestinationCity</td>
                    <td>@trip.StartUtc</td>
                    <td>@trip.EndUtc</td>
                    <td>@trip.TotalTripHours</td>
                </tr>
            }
        </tbody>
    </table>
}

